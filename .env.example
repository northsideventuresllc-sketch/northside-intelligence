# Supabase (NI-Brain) — project kxijunwgbrlfzvgkhklo
NEXT_PUBLIC_SUPABASE_URL=https://kxijunwgbrlfzvgkhklo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: used by billing webhooks, generate routes, auth admin
SUPABASE_SERVICE_ROLE_KEY=
# Gateway secret for the ni-portal-auth Supabase Edge Function (must match vault secret)
NI_AUTH_GATEWAY_SECRET=

# Resend — email 2FA for portal auth
RESEND_API_KEY=
RESEND_FROM_EMAIL=Northside Intelligence <auth@northsideintelligence.com>

# Kit (ConvertKit) — NI email list subscriptions (v3: API key + secret + numeric form ID)
KIT_API_KEY=
KIT_API_SECRET=
KIT_FORM_ID=

# Ops dashboard auth — generate: openssl rand -hex 20
# Also used to encrypt pending signup/signin payloads for 2FA
NI_ADMIN_SECRET=
# Signs httpOnly ni_ops_token session cookies (generate: openssl rand -hex 32)
OPS_SESSION_SECRET=

# App URL (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared auth cookie across *.northsideintelligence.com (portal + Sector 3 tools)
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.northsideintelligence.com

# ReplyFlow (hosted at /replyflow on the portal)
NEXT_PUBLIC_REPLYFLOW_URL=https://northsideintelligence.com/replyflow
# ReplyFlow AI: uses Vercel AI Gateway (OIDC on Vercel; run `vercel env pull` locally).
# Optional fallbacks for local dev or non-Vercel hosts:
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=

# Stripe — required for NI subscriptions, toolkit purchases, and ReplyFlow legacy billing
# Production may also load live keys from ni_platform_secrets (NI-Brain) when env is unset.
STRIPE_SECRET_KEY=
# Billing webhook: /api/billing/webhooks/stripe
STRIPE_WEBHOOK_SECRET=
# ReplyFlow legacy webhook: /api/replyflow/webhooks/stripe (falls back to STRIPE_WEBHOOK_SECRET)
STRIPE_REPLYFLOW_WEBHOOK_SECRET=

# NI subscription tiers (Core / Pro / Power — also stored in Supabase ni_plan_pricing)
STRIPE_NI_CORE_MONTHLY_PRICE_ID=
STRIPE_NI_CORE_ANNUAL_PRICE_ID=
STRIPE_NI_PRO_MONTHLY_PRICE_ID=
STRIPE_NI_PRO_ANNUAL_PRICE_ID=
STRIPE_NI_POWER_MONTHLY_PRICE_ID=
STRIPE_NI_POWER_ANNUAL_PRICE_ID=

# Lifetime launch window (off until 5+ users; then set start timestamp for 7-day window)
LIFETIME_LAUNCH_ENABLED=false
# LIFETIME_LAUNCH_START_AT=2026-06-18T00:00:00.000Z

# ReplyFlow legacy per-tool plans (optional if using NI subscriptions only)
STRIPE_SOLO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Smart Store (dropship — shop.northsideintelligence.com /store)
# Webhook: /api/store/webhook (separate from billing webhook; legacy alias /api/store/webhooks/stripe)
STRIPE_WEBHOOK_SECRET_STORE=
MAKE_STORE_WEBHOOK_URL=
# CJ API — enriches daily viral picks when set
CJ_DROPSHIPPING_API_KEY=
# Optional: Google Images fallback when supplier image is missing (serpapi.com)
SERPAPI_API_KEY=
NI_STORE_LIVE=false
# Vercel cron auth for /api/cron/store-viral-refresh (daily viral reset)
CRON_SECRET=

TIER=pro
