# Supabase (NI-Brain) — project kxijunwgbrlfzvgkhklo
NEXT_PUBLIC_SUPABASE_URL=https://kxijunwgbrlfzvgkhklo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: not required when ReplyFlow routes proxy to ni-replyflow edge function
SUPABASE_SERVICE_ROLE_KEY=
# Gateway secret for Supabase Edge Functions (must match vault ni_portal_admin_secret)
NI_AUTH_GATEWAY_SECRET=
# Optional alias for ReplyFlow edge proxy (defaults to NI_AUTH_GATEWAY_SECRET)
NI_REPLYFLOW_GATEWAY_SECRET=

# Resend — email 2FA for portal auth
RESEND_API_KEY=
RESEND_FROM_EMAIL=Northside Intelligence <auth@northsideintelligence.com>

# Ops dashboard auth — generate: openssl rand -hex 20
# Also used to encrypt pending signup/signin payloads for 2FA
NI_ADMIN_SECRET=

# App URL (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared auth cookie across *.northsideintelligence.com (portal + Sector 3 tools)
NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.northsideintelligence.com

# ReplyFlow (hosted at /replyflow on the portal)
NEXT_PUBLIC_REPLYFLOW_URL=https://northsideintelligence.com/replyflow
# Stored in Supabase Vault (ni_anthropic_api_key, ni_stripe_secret_key, ni_stripe_webhook_secret)
# when using the ni-replyflow edge function; optional here for local dev without edge.
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=
TIER=pro
